                     <a href="#" style="color:#F2C94C" @click="_setMode('interactive')">Modo Vista Interactiva</a>
                </div>
                <div class="col-6">
                    <a href="#" style="color:#F2C94C " @click="_setMode('atlas')">Modo Vista Atlas</a>
                </div>

            </div>
